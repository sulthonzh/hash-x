{
  "name": "hash-x",
  "version": "1.2.0",
  "description": "Zero-dependency non-cryptographic hash functions: MurmurHash3, XXHash32, FNV-1a, CRC32, Adler32, DJB2, JavaHash",
  "main": "index.js",
  "bin": {
    "hash-x": "cli.js"
  },
  "scripts": {
    "test": "node --test test/index.test.js",
    "test:core": "node --test test/index.test.js",
    "test:coverage": "c8 --reporter=text node --test test/index.test.js",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "hash",
    "murmurhash",
    "xxhash",
    "fnv",
    "crc32",
    "adler32",
    "djb2",
    "non-cryptographic",
    "checksum"
  ],
  "license": "MIT",
  "author": "sulthonzh",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "files": [
    "index.js",
    "cli.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/hash-x.git"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "c8": "^11.0.0"
  }
}
